<launch>
    <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
        <param name="video_device" value="/dev/video3" />
        <param name="image_width" value="640" />
        <param name="image_height" value="480" />
    </node>
    <!-- <node name="base_controller" pkg="mecanum_robot" type="base_control_setpoint_node.py" output="screen" /> -->
    <node name="deteksi_basic" pkg="mecanum_robot" type="deteksi_basic_node.py" output="screen" />
</launch>