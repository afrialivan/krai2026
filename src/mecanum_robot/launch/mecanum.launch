<launch>
    <node name="usb_cam" pkg="usb_cam" type="usb_cam_node" output="screen">
        <param name="video_device" value="/dev/video1" />
        <param name="image_width" value="640" />
        <param name="image_height" value="480" />
        <param name="pixel_format" value="yuyv" />
    </node>

    <node name="base_controller" pkg="mecanum_robot" type="base_controller.py" output="screen">
        </node>

    <node name="yolo_detector" pkg="mecanum_robot" type="yolo_detector.py" output="screen">
    </node>

    <!-- <node name="teleop_twist_keyboard" pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py" output="screen" launch-prefix="xterm -e">
    </node> -->
</launch>